! Colors
#define foreground       #CFD8DC
#define background       #212121
#define cursor           #CFD8DC
#define white            #F5F5F5
#define light_grey       #E0E0E0
#define light_red        #EF9A9A
#define red              #E57373
#define light_yellow     #FFD54F
#define yellow           #FFC107
#define light_green      #C5E1A5
#define green            #AED581
#define light_cyan       #80DEEA
#define cyan             #4DD0E1
#define light_blue       #90CAF9
#define blue             #64B5F6
#define light_magenta    #CE93D8
#define magenta          #BA68C8
#define dark_grey        #616161
#define black            #212121


! X11
Xft.dpi:                 192
Xft.antialias:           true
Xft.hinting:             true
Xft.hintstyle:           hintfull
Xft.lcdfilter:           lcddefault
Xft.rgba:                rgb
Xcursor.size:            48

! URxvt
*.foreground:            foreground
*.background:            background
*.cursorColor:           cursor

! black
*.color0:                black
*.color8:                dark_grey

! red
*.color1:                red
*.color9:                light_red

! green
*.color2:                green
*.color10:               light_green

! yellow
*.color3:                yellow
*.color11:               light_yellow

! blue
*.color4:                blue
*.color12:               light_blue

! magenta
*.color5:                magenta
*.color13:               light_magenta

! cyan
*.color6:                cyan
*.color14:               light_cyan

! white
*.color7:                light_grey
*.color15:               white

URxvt.tabbed.tabbar-fg:  15
URxvt.tabbed.tabbar-bg:  -1
URxvt.tabbed.tab-fg:     15
URxvt.tabbed.tab-bg:     -1

URxvt.iso14755:          false
URxvt.iso14755_52:       false
URxvt.scrollBar:         false
URxvt*depth:             32
URxvt*cursorBlink:       true
URxvt*internalBorder:    20
URxvt*font:              xft:Hasklig:style=Regular:size=10,xft:Unifont,size=10
URxvt.perl-ext-common:   default,matcher,resize-font,tabbed
URxvt.tabbed.new-button: false